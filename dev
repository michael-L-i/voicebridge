#!/bin/bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
DEV_DATA_ROOT="${CADENCE_CODE_DEV_DATA_ROOT:-${REPO_ROOT}/.cadence-code-dev}"

usage() {
  cat <<'EOF'
Usage: ./dev <command> [options]

Commands:
  check       Run local validation and unit tests
  inspector   Open the checkout's MCP server in MCP Inspector
  claude      Launch Claude Code with the checkout loaded directly
  codex       Launch Codex with the checkout's MCP server directly
  cursor      Launch Cursor Agent with the checkout loaded directly
  agy         Launch Antigravity CLI with the checkout loaded directly
  reset       Remove all isolated local-development state
EOF
}

check_help() {
  cat <<'EOF'
Usage: ./dev check

Run Bash syntax checks, unit tests, and installed-host plugin validators.
This does not install dependencies or download speech models.
EOF
}

inspector_help() {
  cat <<'EOF'
Usage: ./dev inspector

Launch the checkout's stdio MCP server in the official MCP Inspector with
isolated development data. The bootstrap installs Python dependencies on its
first run; speech model weights are downloaded only if you call voice_start.
EOF
}

claude_help() {
  cat <<'EOF'
Usage: ./dev claude [--fresh] [claude-options]

Launch Claude Code from the repository root with this checkout loaded through
--plugin-dir. Nothing is installed from a marketplace. Inside Claude Code, run
/cadence-code:start-talking to start the local voice flow. Use --fresh to clear the
development configuration and onboarding marker while keeping the private venv.
EOF
}

codex_help() {
  cat <<'EOF'
Usage: ./dev codex [--fresh] [codex-options]

Launch Codex from the repository root with one-session MCP configuration that
points directly at this checkout. Nothing is installed from a marketplace and
no user Codex configuration is changed. Inside Codex, run $start-talking. Use
--fresh to clear the development configuration and onboarding marker while
keeping the private venv.
EOF
}

cursor_help() {
  cat <<'EOF'
Usage: ./dev cursor [--fresh] [cursor-agent-options]

Launch Cursor Agent from the repository root. The checkout's workspace MCP
configuration and shared Agent Skills load directly; no plugin is installed and
no user Cursor configuration is changed. Inside Cursor, run /start-talking.
Use --fresh to clear the development configuration and onboarding marker while
keeping the private venv.
EOF
}

agy_help() {
  cat <<'EOF'
Usage: ./dev agy [--fresh] [agy-options]

Launch Antigravity CLI from the repository root. The checkout's workspace MCP
configuration and shared Agent Skills load directly; no plugin is installed and
no user Antigravity configuration is changed. Inside AGY, run /start-talking.
Use --fresh to clear the development configuration and onboarding marker while
keeping the private venv.
EOF
}

reset_help() {
  cat <<'EOF'
Usage: ./dev reset

Move the checkout's complete .cadence-code-dev directory to macOS Trash. This
removes development venvs, configuration, and onboarding state for Inspector,
Claude Code, Codex, Cursor, and Antigravity. Production plugin data and shared
model caches are not touched. Close every Cadence Code host session before
running this command.
EOF
}

development_dir() {
  local name="$1"
  local root_real
  local directory="${DEV_DATA_ROOT}/${name}"

  mkdir -p "${DEV_DATA_ROOT}" "${directory}"
  root_real=$(cd "${DEV_DATA_ROOT}" && pwd -P)
  local directory_real
  directory_real=$(cd "${directory}" && pwd -P)
  case "${directory_real}/" in
    "${root_real}/"*)
      printf '%s\n' "${directory_real}"
      ;;
    *)
      echo "[cadence-code-dev] ERROR: refusing data path outside ${root_real}" >&2
      exit 1
      ;;
  esac
}

reset_onboarding() {
  local directory="$1"
  rm -f -- "${directory}/config.toml" "${directory}/onboarding-v1.complete"
}

run_reset() {
  if [ "${1:-}" = "--help" ]; then
    reset_help
    return
  fi
  if [ "$#" -ne 0 ]; then
    reset_help >&2
    exit 2
  fi
  if [ ! -e "${DEV_DATA_ROOT}" ]; then
    echo "[cadence-code-dev] no development data to reset"
    return
  fi

  local data_root_real
  data_root_real=$(cd "${DEV_DATA_ROOT}" && pwd -P)
  if [ "$(basename "${data_root_real}")" != ".cadence-code-dev" ]; then
    echo "[cadence-code-dev] ERROR: refusing to reset unsafe path: ${data_root_real}" >&2
    exit 1
  fi

  local pgrep_bin="${CADENCE_CODE_DEV_PGREP_BIN:-pgrep}"
  if command -v "${pgrep_bin}" >/dev/null 2>&1 && \
     "${pgrep_bin}" -f '[c]adence-code-mcp' >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: stop every Cadence Code host session before reset." >&2
    exit 1
  fi

  local trash_bin="${CADENCE_CODE_DEV_TRASH_BIN:-/usr/bin/trash}"
  if [ ! -x "${trash_bin}" ]; then
    echo "[cadence-code-dev] ERROR: macOS trash command is unavailable." >&2
    exit 1
  fi
  "${trash_bin}" "${data_root_real}"
  echo "[cadence-code-dev] moved ${data_root_real} to Trash"
}

python_bin() {
  if [ -x "${REPO_ROOT}/.venv/bin/python" ]; then
    printf '%s\n' "${REPO_ROOT}/.venv/bin/python"
    return
  fi
  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return
  fi
  echo "[cadence-code-dev] ERROR: Python 3 is required." >&2
  exit 1
}

run_check() {
  if [ "${1:-}" = "--help" ]; then
    check_help
    return
  fi
  if [ "$#" -ne 0 ]; then
    check_help >&2
    exit 2
  fi

  local python
  python=$(python_bin)

  echo "[cadence-code-dev] checking Bash scripts"
  bash -n "${REPO_ROOT}/dev" "${REPO_ROOT}/bin/cadence-code-mcp-bootstrap"

  echo "[cadence-code-dev] running unit tests"
  "${python}" -m unittest discover -s "${REPO_ROOT}/tests" -v

  if command -v claude >/dev/null 2>&1; then
    echo "[cadence-code-dev] validating Claude plugin"
    claude plugin validate --strict "${REPO_ROOT}"
  else
    echo "[cadence-code-dev] Claude Code is not installed; skipping plugin validation" >&2
  fi

  if command -v agy >/dev/null 2>&1; then
    echo "[cadence-code-dev] validating Antigravity plugin"
    agy plugin validate "${REPO_ROOT}"
  else
    echo "[cadence-code-dev] Antigravity CLI is not installed; skipping plugin validation" >&2
  fi
}

run_inspector() {
  if [ "${1:-}" = "--help" ]; then
    inspector_help
    return
  fi
  if [ "$#" -ne 0 ]; then
    inspector_help >&2
    exit 2
  fi

  local npx_bin="${CADENCE_CODE_DEV_NPX_BIN:-npx}"
  if ! command -v "${npx_bin}" >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: npx is required for MCP Inspector." >&2
    exit 1
  fi

  local data_dir
  data_dir=$(development_dir inspector)
  exec "${npx_bin}" -y @modelcontextprotocol/inspector \
    env \
    "CADENCE_CODE_DATA_DIR=${data_dir}" \
    "CADENCE_CODE_HOST=inspector" \
    "${REPO_ROOT}/bin/cadence-code-mcp-bootstrap"
}

run_claude() {
  if [ "${1:-}" = "--help" ]; then
    claude_help
    return
  fi

  local fresh=0
  local -a claude_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fresh)
        fresh=1
        ;;
      *)
        claude_args+=("$1")
        ;;
    esac
    shift
  done

  local claude_bin="${CADENCE_CODE_DEV_CLAUDE_BIN:-claude}"
  if ! command -v "${claude_bin}" >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: Claude Code is not installed." >&2
    exit 1
  fi

  local data_dir
  data_dir=$(development_dir claude)
  if [ "${fresh}" = "1" ]; then
    reset_onboarding "${data_dir}"
    echo "[cadence-code-dev] reset Claude development onboarding"
  fi
  cd "${REPO_ROOT}"
  export CADENCE_CODE_DEV_DATA_DIR="${data_dir}"
  if [ "${#claude_args[@]}" -eq 0 ]; then
    exec "${claude_bin}" --plugin-dir "${REPO_ROOT}"
  fi
  exec "${claude_bin}" --plugin-dir "${REPO_ROOT}" "${claude_args[@]}"
}

run_codex() {
  if [ "${1:-}" = "--help" ]; then
    codex_help
    return
  fi

  local fresh=0
  local -a codex_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fresh)
        fresh=1
        ;;
      *)
        codex_args+=("$1")
        ;;
    esac
    shift
  done

  local codex_bin="${CADENCE_CODE_DEV_CODEX_BIN:-codex}"
  if ! command -v "${codex_bin}" >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: Codex is not installed." >&2
    exit 1
  fi

  local data_dir
  data_dir=$(development_dir codex)
  if [ "${fresh}" = "1" ]; then
    reset_onboarding "${data_dir}"
    echo "[cadence-code-dev] reset Codex development onboarding"
  fi
  unset CADENCE_CODE_DEV_DATA_DIR
  cd "${REPO_ROOT}"
  local -a cadence_code_config=(
    -C "${REPO_ROOT}"
    -c "mcp_servers.cadence-code.command=${REPO_ROOT}/bin/cadence-code-mcp-bootstrap"
    -c "mcp_servers.cadence-code.cwd=${REPO_ROOT}"
    -c "mcp_servers.cadence-code.env.CADENCE_CODE_DATA_DIR=${data_dir}"
    -c "mcp_servers.cadence-code.env.CADENCE_CODE_HOST=codex"
    -c "mcp_servers.cadence-code.startup_timeout_sec=900"
    -c "mcp_servers.cadence-code.tool_timeout_sec=1800"
    -c "mcp_servers.cadence-code.default_tools_approval_mode=approve"
    -c "mcp_servers.cadence-code.required=true"
  )
  if [ "${#codex_args[@]}" -eq 0 ]; then
    exec "${codex_bin}" "${cadence_code_config[@]}"
  fi
  exec "${codex_bin}" "${cadence_code_config[@]}" "${codex_args[@]}"
}

run_cursor() {
  if [ "${1:-}" = "--help" ]; then
    cursor_help
    return
  fi

  local fresh=0
  local -a cursor_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fresh)
        fresh=1
        ;;
      *)
        cursor_args+=("$1")
        ;;
    esac
    shift
  done

  local cursor_bin="${CADENCE_CODE_DEV_CURSOR_BIN:-agent}"
  if ! command -v "${cursor_bin}" >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: Cursor Agent is not installed." >&2
    exit 1
  fi

  local data_dir
  data_dir=$(development_dir cursor)
  if [ "${fresh}" = "1" ]; then
    reset_onboarding "${data_dir}"
    echo "[cadence-code-dev] reset Cursor development onboarding"
  fi
  cd "${REPO_ROOT}"
  export CADENCE_CODE_DATA_DIR="${data_dir}"
  export CADENCE_CODE_HOST="cursor"
  if [ "${#cursor_args[@]}" -eq 0 ]; then
    exec "${cursor_bin}" --workspace "${REPO_ROOT}"
  fi
  exec "${cursor_bin}" --workspace "${REPO_ROOT}" "${cursor_args[@]}"
}

run_agy() {
  if [ "${1:-}" = "--help" ]; then
    agy_help
    return
  fi

  local fresh=0
  local -a agy_args=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --fresh)
        fresh=1
        ;;
      *)
        agy_args+=("$1")
        ;;
    esac
    shift
  done

  local agy_bin="${CADENCE_CODE_DEV_AGY_BIN:-agy}"
  if ! command -v "${agy_bin}" >/dev/null 2>&1; then
    echo "[cadence-code-dev] ERROR: Antigravity CLI is not installed." >&2
    exit 1
  fi

  local data_dir
  data_dir=$(development_dir antigravity)
  if [ "${fresh}" = "1" ]; then
    reset_onboarding "${data_dir}"
    echo "[cadence-code-dev] reset Antigravity development onboarding"
  fi
  cd "${REPO_ROOT}"
  export CADENCE_CODE_DATA_DIR="${data_dir}"
  export CADENCE_CODE_HOST="antigravity"
  if [ "${#agy_args[@]}" -eq 0 ]; then
    exec "${agy_bin}"
  fi
  exec "${agy_bin}" "${agy_args[@]}"
}

case "${1:-}" in
  check)
    shift
    run_check "$@"
    ;;
  inspector)
    shift
    run_inspector "$@"
    ;;
  claude)
    shift
    run_claude "$@"
    ;;
  codex)
    shift
    run_codex "$@"
    ;;
  cursor)
    shift
    run_cursor "$@"
    ;;
  agy|antigravity)
    shift
    run_agy "$@"
    ;;
  reset)
    shift
    run_reset "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "[cadence-code-dev] ERROR: unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
