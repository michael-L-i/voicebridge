#!/bin/bash
set -euo pipefail

REPO_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)
DEV_DATA_ROOT="${VOICEBRIDGE_DEV_DATA_ROOT:-${REPO_ROOT}/.voicebridge-dev}"

usage() {
  cat <<'EOF'
Usage: ./dev <command> [options]

Commands:
  check       Run local validation and unit tests
  inspector   Open the checkout's MCP server in MCP Inspector
  claude      Launch Claude Code with the checkout loaded directly
EOF
}

check_help() {
  cat <<'EOF'
Usage: ./dev check

Run Bash syntax checks, the Python unit tests, and strict Claude plugin
validation when the Claude Code CLI is installed. This command does not install
dependencies or download speech models.
EOF
}

inspector_help() {
  cat <<'EOF'
Usage: ./dev inspector

Launch the checkout's stdio MCP server in the official MCP Inspector with
isolated development data. The bootstrap installs Python dependencies on its
first run; speech model weights are downloaded only if you call voice_start.
EOF
}

claude_help() {
  cat <<'EOF'
Usage: ./dev claude [claude-options]

Launch Claude Code from the repository root with this checkout loaded through
--plugin-dir. Nothing is installed from a marketplace. Inside Claude Code, run
/voicebridge:voice-code to start the local voice flow.
EOF
}

python_bin() {
  if [ -x "${REPO_ROOT}/.venv/bin/python" ]; then
    printf '%s\n' "${REPO_ROOT}/.venv/bin/python"
    return
  fi
  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return
  fi
  echo "[voicebridge-dev] ERROR: Python 3 is required." >&2
  exit 1
}

run_check() {
  if [ "${1:-}" = "--help" ]; then
    check_help
    return
  fi
  if [ "$#" -ne 0 ]; then
    check_help >&2
    exit 2
  fi

  local python
  python=$(python_bin)

  echo "[voicebridge-dev] checking Bash scripts"
  bash -n "${REPO_ROOT}/dev" "${REPO_ROOT}/bin/voicebridge-mcp-bootstrap"

  echo "[voicebridge-dev] running unit tests"
  "${python}" -m unittest discover -s "${REPO_ROOT}/tests" -v

  if command -v claude >/dev/null 2>&1; then
    echo "[voicebridge-dev] validating Claude plugin"
    claude plugin validate --strict "${REPO_ROOT}"
  else
    echo "[voicebridge-dev] Claude Code is not installed; skipping plugin validation" >&2
  fi
}

run_inspector() {
  if [ "${1:-}" = "--help" ]; then
    inspector_help
    return
  fi
  if [ "$#" -ne 0 ]; then
    inspector_help >&2
    exit 2
  fi

  local npx_bin="${VOICEBRIDGE_DEV_NPX_BIN:-npx}"
  if ! command -v "${npx_bin}" >/dev/null 2>&1; then
    echo "[voicebridge-dev] ERROR: npx is required for MCP Inspector." >&2
    exit 1
  fi

  mkdir -p "${DEV_DATA_ROOT}/inspector"
  exec "${npx_bin}" -y @modelcontextprotocol/inspector \
    env \
    "VOICEBRIDGE_DATA_DIR=${DEV_DATA_ROOT}/inspector" \
    "VOICEBRIDGE_HOST=inspector" \
    "${REPO_ROOT}/bin/voicebridge-mcp-bootstrap"
}

run_claude() {
  if [ "${1:-}" = "--help" ]; then
    claude_help
    return
  fi

  local claude_bin="${VOICEBRIDGE_DEV_CLAUDE_BIN:-claude}"
  if ! command -v "${claude_bin}" >/dev/null 2>&1; then
    echo "[voicebridge-dev] ERROR: Claude Code is not installed." >&2
    exit 1
  fi

  mkdir -p "${DEV_DATA_ROOT}/claude"
  cd "${REPO_ROOT}"
  export VOICEBRIDGE_DEV_DATA_DIR="${DEV_DATA_ROOT}/claude"
  exec "${claude_bin}" --plugin-dir "${REPO_ROOT}" "$@"
}

case "${1:-}" in
  check)
    shift
    run_check "$@"
    ;;
  inspector)
    shift
    run_inspector "$@"
    ;;
  claude)
    shift
    run_claude "$@"
    ;;
  -h|--help|help|"")
    usage
    ;;
  *)
    echo "[voicebridge-dev] ERROR: unknown command: $1" >&2
    usage >&2
    exit 2
    ;;
esac
