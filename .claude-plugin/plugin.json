{
  "name": "cadence-code",
  "version": "0.6.0",
  "description": "Configurable local speech and transcription for natural Claude Code conversations on Apple Silicon.",
  "author": {
    "name": "Michael Li"
  },
  "license": "MIT",
  "mcpServers": {
    "cadence-code": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/cadence-code-mcp-bootstrap",
      "env": {
        "CADENCE_CODE_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "CADENCE_CODE_HOST": "claude-code"
      }
    }
  }
}
