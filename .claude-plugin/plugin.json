{
  "name": "voicebridge",
  "version": "0.4.1",
  "description": "Configurable local speech and transcription for natural Claude Code conversations on Apple Silicon.",
  "author": {
    "name": "Michael Li"
  },
  "license": "MIT",
  "mcpServers": {
    "voicebridge": {
      "command": "${CLAUDE_PLUGIN_ROOT}/bin/voicebridge-mcp-bootstrap",
      "env": {
        "VOICEBRIDGE_DATA_DIR": "${CLAUDE_PLUGIN_DATA}",
        "VOICEBRIDGE_HOST": "claude-code"
      }
    }
  }
}
