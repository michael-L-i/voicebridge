#!/bin/bash
# Declared as this plugin's MCP server command in the plugin manifest. Ensures a
# private venv with voicebridge + its local speech deps (mlx-audio, misaki,
# spacy, ...) exists under the selected data directory, building it on first
# run (or after a plugin update changes the locked dependencies), then execs
# into the real voicebridge-mcp entrypoint inside that venv.
#
# IMPORTANT: stdout is the live MCP stdio JSON-RPC channel. Every log line in
# this script MUST go to stderr (>&2) -- writing anything to stdout before
# the final exec corrupts the protocol handshake the host expects.
set -euo pipefail

PLUGIN_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)
DATA_DIR="${VOICEBRIDGE_DEV_DATA_DIR:-${VOICEBRIDGE_DATA_DIR:-${HOME}/.voicebridge}}"
VENV_DIR="${DATA_DIR}/venv"
MARKER_FILE="${VENV_DIR}/.voicebridge-install-marker"
INSTALL_LOCK_DIR="${DATA_DIR}/.venv-install.lock"
INSTALL_LOCK_OWNER="${INSTALL_LOCK_DIR}/owner"
PYPROJECT="${PLUGIN_ROOT}/pyproject.toml"
REQUIREMENTS="${PLUGIN_ROOT}/requirements.lock"

if [ "$(uname -s)" != "Darwin" ]; then
  echo "[voicebridge] ERROR: VoiceBridge requires macOS on Apple Silicon." >&2
  exit 1
fi
if [ "$(uname -m)" != "arm64" ]; then
  echo "[voicebridge] ERROR: VoiceBridge requires an Apple Silicon (arm64) shell." >&2
  exit 1
fi

mkdir -p "${DATA_DIR}"

if [ ! -f "${REQUIREMENTS}" ]; then
  echo "[voicebridge] ERROR: bundled dependency lock is missing:" >&2
  echo "  ${REQUIREMENTS}" >&2
  exit 1
fi

# A dependency declaration or lock export change invalidates the venv. Pure
# code changes do not, since the editable install already reflects them.
CURRENT_HASH=$(shasum -a 256 "${PYPROJECT}" "${REQUIREMENTS}" | \
  awk '{print $1}' | shasum -a 256 | awk '{print $1}')

environment_is_current() {
  [ -x "${VENV_DIR}/bin/voicebridge-mcp" ] && \
    [ -f "${MARKER_FILE}" ] && \
    [ "$(cat "${MARKER_FILE}")" = "${CURRENT_HASH}" ]
}

process_started_at() {
  ps -p "$1" -o lstart= 2>/dev/null | awk '{$1=$1; print}'
}

LOCK_TOKEN="$$.${RANDOM}.$(date +%s)"
LOCK_STARTED_AT=$(process_started_at "$$")
LOCK_RECORD="$$|${LOCK_STARTED_AT}|${LOCK_TOKEN}"
HAVE_INSTALL_LOCK=0

release_install_lock() {
  if [ "${HAVE_INSTALL_LOCK}" = "1" ] && \
     [ -f "${INSTALL_LOCK_OWNER}" ] && \
     [ "$(cat "${INSTALL_LOCK_OWNER}" 2>/dev/null || true)" = "${LOCK_RECORD}" ]; then
    rm -- "${INSTALL_LOCK_OWNER}"
    rmdir "${INSTALL_LOCK_DIR}" 2>/dev/null || true
  fi
  HAVE_INSTALL_LOCK=0
}

reap_install_lock() {
  EXPECTED_OWNER=$1
  RECOVERY_MESSAGE=$2
  CLAIMED_OWNER="${INSTALL_LOCK_OWNER}.reaping.${LOCK_TOKEN}"

  if [ -e "${INSTALL_LOCK_OWNER}" ]; then
    if [ "$(cat "${INSTALL_LOCK_OWNER}" 2>/dev/null || true)" != \
       "${EXPECTED_OWNER}" ] || \
       ! mv "${INSTALL_LOCK_OWNER}" "${CLAIMED_OWNER}" 2>/dev/null; then
      return 1
    fi
    if [ "$(cat "${CLAIMED_OWNER}" 2>/dev/null || true)" != \
         "${EXPECTED_OWNER}" ]; then
      if [ ! -e "${INSTALL_LOCK_OWNER}" ]; then
        mv "${CLAIMED_OWNER}" "${INSTALL_LOCK_OWNER}" 2>/dev/null || true
      fi
      return 1
    fi
  fi

  # A crashed reaper can leave one of these claims behind. They are lock
  # metadata only; build directories are deliberately never swept here.
  for ABANDONED_CLAIM in "${INSTALL_LOCK_OWNER}".reaping.*; do
    if [ -f "${ABANDONED_CLAIM}" ]; then
      rm -- "${ABANDONED_CLAIM}"
    fi
  done
  if rmdir "${INSTALL_LOCK_DIR}" 2>/dev/null; then
    echo "${RECOVERY_MESSAGE}" >&2
    return 0
  fi
  return 1
}

acquire_install_lock() {
  WAITING_FOR_LOCK=0
  INCOMPLETE_OWNER_ROUNDS=0

  while ! mkdir "${INSTALL_LOCK_DIR}" 2>/dev/null; do
    OWNER_RECORD=$(cat "${INSTALL_LOCK_OWNER}" 2>/dev/null || true)
    OWNER_PID=${OWNER_RECORD%%|*}
    OWNER_REMAINDER=${OWNER_RECORD#*|}
    OWNER_STARTED_AT=${OWNER_REMAINDER%%|*}
    OWNER_TOKEN=${OWNER_REMAINDER#*|}
    OWNER_IS_VALID=1
    case "${OWNER_PID}" in
      ""|*[!0-9]*) OWNER_IS_VALID=0 ;;
    esac
    if [ "${OWNER_REMAINDER}" = "${OWNER_RECORD}" ] || \
       [ "${OWNER_TOKEN}" = "${OWNER_REMAINDER}" ] || \
       [ -z "${OWNER_STARTED_AT}" ] || [ -z "${OWNER_TOKEN}" ]; then
      OWNER_IS_VALID=0
    fi

    OWNER_IS_ACTIVE=0
    if [ "${OWNER_IS_VALID}" = "1" ] && \
       kill -0 "${OWNER_PID}" 2>/dev/null && \
       [ "$(process_started_at "${OWNER_PID}")" = "${OWNER_STARTED_AT}" ]; then
      OWNER_IS_ACTIVE=1
    fi

    if [ "${OWNER_IS_ACTIVE}" = "1" ]; then
      INCOMPLETE_OWNER_ROUNDS=0
    elif [ "${OWNER_IS_VALID}" = "1" ]; then
      # Moving the inspected record is an atomic claim: only one waiter can
      # reap it, and no reaper ever removes a later owner's record.
      if reap_install_lock "${OWNER_RECORD}" \
           "[voicebridge] recovered a stale installer lock."; then
        continue
      fi
    else
      # mkdir and the owner write cannot be one operation in stock Bash. Give
      # a live acquirer time to publish its record before pruning an incomplete
      # lock left by a crash in that tiny window.
      INCOMPLETE_OWNER_ROUNDS=$((INCOMPLETE_OWNER_ROUNDS + 1))
      if [ "${INCOMPLETE_OWNER_ROUNDS}" -ge 5 ]; then
        if reap_install_lock "${OWNER_RECORD}" \
             "[voicebridge] recovered an incomplete installer lock."; then
          continue
        fi
        INCOMPLETE_OWNER_ROUNDS=0
      fi
    fi

    if [ "${WAITING_FOR_LOCK}" = "0" ]; then
      echo "[voicebridge] waiting for another VoiceBridge setup to finish." >&2
      WAITING_FOR_LOCK=1
    fi
    sleep 1
  done

  if ! printf '%s\n' "${LOCK_RECORD}" > "${INSTALL_LOCK_OWNER}"; then
    rmdir "${INSTALL_LOCK_DIR}" 2>/dev/null || true
    echo "[voicebridge] ERROR: could not record installer lock ownership." >&2
    exit 1
  fi
  HAVE_INSTALL_LOCK=1
  trap release_install_lock EXIT
}

if ! environment_is_current; then
  acquire_install_lock

  # Another caller may have completed setup while this process waited.
  if environment_is_current; then
    release_install_lock
    trap - EXIT
    exec "${VENV_DIR}/bin/voicebridge-mcp"
  fi

  echo "[voicebridge] setting up local voice models -- first run only," \
       "can take a few minutes (dependency install; model weights download" \
       "when voice mode starts for the first time)." >&2

  PYTHON_BIN="${VOICEBRIDGE_PYTHON:-}"
  if [ -z "${PYTHON_BIN}" ]; then
    PYTHON_BIN=$(command -v python3.13 || command -v python3.12 || \
      command -v python3.11 || command -v python3 || true)
  fi
  if [ -z "${PYTHON_BIN}" ]; then
    echo "[voicebridge] ERROR: no python3 found on PATH. Install Python 3.11+" \
         "(e.g. brew install python@3.12) and start a new session." >&2
    exit 1
  fi
  # A symlinked interpreter (common with uv-managed Python) can make venv
  # record the symlink directory as its runtime home and fail in ensurepip.
  PYTHON_BIN=$("${PYTHON_BIN}" -c \
    'import os, sys; print(os.path.realpath(sys.executable))')
  if ! "${PYTHON_BIN}" -c 'import sys; raise SystemExit(sys.version_info < (3, 11))'; then
    PYTHON_VERSION=$("${PYTHON_BIN}" -c \
      'import sys; print(".".join(map(str, sys.version_info[:3])))')
    echo "[voicebridge] ERROR: Python 3.11+ is required; found ${PYTHON_VERSION}." >&2
    echo "  Install it with: brew install python@3.12" >&2
    exit 1
  fi

  # Build at its permanent path so venv shebangs remain valid. The stable
  # venv path is switched only after every install step succeeds.
  BUILD_DIR=$(mktemp -d "${DATA_DIR}/.venv-build.XXXXXX")
  NEXT_LINK=""
  cleanup_install() {
    if [ -n "${NEXT_LINK}" ] && [ -L "${NEXT_LINK}" ]; then
      rm -- "${NEXT_LINK}"
    fi
    if [ -n "${BUILD_DIR}" ] && [ -d "${BUILD_DIR}" ]; then
      rm -rf -- "${BUILD_DIR}"
    fi
    release_install_lock
  }
  trap cleanup_install EXIT

  "${PYTHON_BIN}" -m venv "${BUILD_DIR}"
  "${BUILD_DIR}/bin/pip" install --quiet --upgrade pip >&2
  # misaki 0.9.4 declares Python <3.13 even though the locked release is
  # exercised on 3.11-3.14 in CI; uv installs it across that supported matrix.
  if ! "${BUILD_DIR}/bin/pip" install --quiet --require-hashes \
    --ignore-requires-python -r "${REQUIREMENTS}" >&2 || \
     ! "${BUILD_DIR}/bin/pip" install --quiet --no-deps \
    -e "${PLUGIN_ROOT}" >&2; then
    echo "[voicebridge] ERROR: locked dependency install failed." >&2
    echo "  The previous environment is unchanged; restart to retry." >&2
    exit 1
  fi
  echo "${CURRENT_HASH}" > "${BUILD_DIR}/.voicebridge-install-marker"

  NEXT_LINK=$(mktemp -d "${DATA_DIR}/.venv-link.XXXXXX")
  rmdir "${NEXT_LINK}"
  ln -s "${BUILD_DIR}" "${NEXT_LINK}"

  OLD_TARGET=""
  if [ -L "${VENV_DIR}" ]; then
    OLD_TARGET=$(readlink "${VENV_DIR}")
    case "${OLD_TARGET}" in
      /*) ;;
      *) OLD_TARGET="${DATA_DIR}/${OLD_TARGET}" ;;
    esac
    mv -f "${NEXT_LINK}" "${VENV_DIR}"
  elif [ -e "${VENV_DIR}" ]; then
    # Migrate the legacy real directory only after the replacement is ready.
    OLD_TARGET=$(mktemp -d "${DATA_DIR}/.venv-previous.XXXXXX")
    rmdir "${OLD_TARGET}"
    mv "${VENV_DIR}" "${OLD_TARGET}"
    if ! mv "${NEXT_LINK}" "${VENV_DIR}"; then
      mv "${OLD_TARGET}" "${VENV_DIR}"
      echo "[voicebridge] ERROR: could not activate the new environment." >&2
      exit 1
    fi
  else
    mv "${NEXT_LINK}" "${VENV_DIR}"
  fi
  NEXT_LINK=""
  BUILD_DIR=""

  # Only remove environments created or migrated by this bootstrap.
  case "${OLD_TARGET}" in
    "${DATA_DIR}"/.venv-build.*|"${DATA_DIR}"/.venv-previous.*)
      rm -rf -- "${OLD_TARGET}"
      ;;
  esac
  release_install_lock
  trap - EXIT
  echo "[voicebridge] setup complete." >&2
fi

exec "${VENV_DIR}/bin/voicebridge-mcp"
