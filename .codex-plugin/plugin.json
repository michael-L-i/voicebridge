{
  "name": "cadence-code",
  "version": "0.6.0",
  "description": "Fully local voice conversations for Codex and Claude Code on Apple Silicon.",
  "author": {
    "name": "Michael Li",
    "url": "https://github.com/michael-L-i"
  },
  "homepage": "https://github.com/michael-L-i/cadence-code",
  "repository": "https://github.com/michael-L-i/cadence-code",
  "license": "MIT",
  "keywords": [
    "apple-silicon",
    "codex",
    "mlx",
    "speech-to-text",
    "text-to-speech",
    "voice-assistant"
  ],
  "skills": "./skills/",
  "mcpServers": {
    "cadence-code": {
      "type": "stdio",
      "command": "bash",
      "args": [
        "./bin/cadence-code-mcp-bootstrap"
      ],
      "cwd": ".",
      "env": {
        "CADENCE_CODE_HOST": "codex"
      },
      "startup_timeout_sec": 900,
      "tool_timeout_sec": 1800,
      "default_tools_approval_mode": "approve"
    }
  },
  "interface": {
    "displayName": "Cadence Code",
    "shortDescription": "Local voice conversations for Codex",
    "longDescription": "Talk naturally with Codex using selectable local speech and transcription models on Apple Silicon.",
    "developerName": "Michael Li",
    "category": "Productivity",
    "capabilities": [
      "Interactive"
    ],
    "websiteURL": "https://github.com/michael-L-i/cadence-code",
    "privacyPolicyURL": "https://github.com/michael-L-i/cadence-code/blob/main/PRIVACY.md",
    "defaultPrompt": [
      "Start a local voice coding conversation.",
      "Choose Cadence Code speech and transcription models."
    ]
  }
}
